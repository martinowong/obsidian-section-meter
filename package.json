{
  "name": "obsidian-section-writing-stats",
  "version": "1.0.2",
  "description": "Show live word counts, character counts, reading time, and writing-goal progress for every section in Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "build:local": "node scripts/build-local.mjs",
    "lint": "eslint main.ts src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "word-count",
    "character-count",
    "writing-stats",
    "writing-goals",
    "reading-time",
    "headings",
    "markdown",
    "productivity",
    "writing-tools"
  ],
  "author": "Martino Wong",
  "license": "MIT",
  "homepage": "https://github.com/martinowong/obsidian-section-meter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martinowong/obsidian-section-meter.git"
  },
  "bugs": {
    "url": "https://github.com/martinowong/obsidian-section-meter/issues"
  },
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "^6.38.2",
    "@types/node": "^22.15.29",
    "@typescript-eslint/parser": "^8.61.1",
    "esbuild": "^0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
